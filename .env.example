# =====================================================================
#  Environment variables — copy to .env and fill in. NEVER commit .env.
#  (The anon/public key lives in db.js and is public-safe; it is NOT here.)
# =====================================================================

# --- Used by the fixtures importer (scripts/import_fixtures.mjs) ---
# Your Supabase project URL, e.g. https://YOUR-PROJECT.supabase.co
SUPABASE_URL=

# Supabase SERVICE-ROLE key (Project Settings → API). It bypasses RLS and can
# write, so keep it secret and local-only — never commit it or expose it client-side.
SUPABASE_SERVICE_KEY=

# --- Used by the sync Edge Function (supabase/functions/sync/index.ts) ---
# football-data.org API token (free tier). Set in Supabase with:
#   supabase secrets set FOOTBALL_DATA_TOKEN=your_token
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected into the function automatically.
FOOTBALL_DATA_TOKEN=
